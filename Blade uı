local VisualizerEnabled = getgenv().visualizer

local function CreateVisualizerPart(name, color, parent)
    local part = Instance.new("Part")
    part.Name = name
    part.Anchored = true
    part.Size = Vector3.new(10, 0.4, 10)
    part.Color = color
    part.CanCollide = false
    part.CastShadow = false
    part.CanQuery = false
    part.Transparency = 1
    local mesh = Instance.new("SpecialMesh")
    mesh.Parent = part
    mesh.MeshType = Enum.MeshType.FileMesh
    mesh.MeshId = "rbxassetid://471124075"
    mesh.Scale = Vector3.new(0.067, 0.042, 0.067)
    part.Parent = parent
    return part
end

local VisualizerRoot = CreateVisualizerPart("Visualizer", Color3.new(1, 0, 0), Workspace)
local VisualizerFollowBall = CreateVisualizerPart("VisualizerFollowBall", Color3.new(1, 0, 0), Workspace)
local VisualizerNoUnit = CreateVisualizerPart("VisualizerNoUnit", Color3.new(1, 0, 1), Workspace)
local VisualizerFollowBallNoUnit = CreateVisualizerPart("VisualizerFollowBallNoUnit", Color3.new(1, 0, 1), Workspace)

