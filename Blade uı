local function GetTargetBall()
    for _, ball in pairs(Workspace.Balls:GetChildren()) do
        if ball:IsA("BasePart") and ball.Velocity ~= Vector3.zero then
            return ball
        end
    end
    return nil
end

local function Round(num, decimalPlaces)
    local mult = 10 ^ (decimalPlaces or 0)
    return math.floor(num * mult + 0.5) / mult
end

UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.X then
        VisualizerEnabled = not VisualizerEnabled
        getgenv().visualizer = VisualizerEnabled
    end
end)

RunService.RenderStepped:Connect(function()
    local enabled = getgenv().visualizer
    local transparency = enabled and 0 or 1
    local billboardEnabled = enabled

    VisualizerRoot.Transparency = transparency
    VisualizerFollowBall.Transparency = transparency
    VisualizerNoUnit.Transparency = transparency
    VisualizerFollowBallNoUnit.Transparency = transparency
    RangeBillboard.Enabled = billboardEnabled
    DistanceBillboard.Enabled = billboardEnabled

    if not enabled then return end

    local character = LocalPlayer.Character
    if not character then return end

    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    local ball = GetTargetBall()
    if not ball then return end

    VisualizerRoot.CFrame = rootPart.CFrame
    VisualizerNoUnit.CFrame = rootPart.CFrame

    local lookAtCFrame = CFrame.lookAt(rootPart.Position, ball.Position)
    VisualizerFollowBall.CFrame = lookAtCFrame
    VisualizerFollowBallNoUnit.CFrame = lookAtCFrame

    RangeBillboard.Adornee = rootPart
    DistanceBillboard.Adornee = ball

    local distance = (rootPart.Position - ball.Position).Magnitude
    local speed = ball.Velocity.Magnitude
    local ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
    local directionFactor = (ball.Velocity.Unit - CFrame.new(ball.Position, rootPart.Position).LookVector).Magnitude
    local prediction = (ping / 9) + (speed * 0.3)
    local multiplier = 1.1 - (directionFactor / 4)

    RangeText.Text = tostring(math.floor(prediction))
    RangeMultiText.Text = tostring(Round(multiplier, 2)) .. "x"
    DistanceText.Text = tostring(math.floor(distance))
end)

getgenv().GetBall = GetTargetBall
getgenv().Round = Round
